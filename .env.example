DMM_API_ID=your_api_id
DMM_AFFILIATE_ID=your_affiliate_id
# Items per page (max 12). Infinite scroll loads additional pages.
FANZA_HITS=8
# Search provider behavior:
# auto: unified first, fall back to source-tabs on partial failure/slow response
# unified: always unified list
# source_tabs: always source-separated tabs
MULTI_SEARCH_MODE=auto
# Timeout per provider call (milliseconds)
PROVIDER_TIMEOUT_MS=3000
# In auto mode, switch to source-tabs when total provider time exceeds this
MULTI_FALLBACK_SLOW_MS=2400

# Optional: first extra HTTP JSON provider (legacy name; id=partner)
# Contract (same as R18_HTTP_PROVIDER_*):
# GET {base}/search?q=&page=&sort=... (& optional cat, gte_date, lte_date)
# GET {base}/items/{id}
R18_PARTNER_API_BASE_URL=
R18_PARTNER_LABEL=R18 Partner
R18_PARTNER_API_KEY=
R18_PARTNER_API_KEY_HEADER=x-api-key
R18_PARTNER_AFFILIATE_FALLBACK_URL=#
# Merge priority when collapsing title+date duplicates (lower wins after FANZA=0)
R18_PARTNER_MERGE_PRIORITY=10

# Optional: up to 5 additional registered HTTP JSON providers (official APIs you contract separately)
# R18_HTTP_PROVIDER_1_ID=r18_http_1
# R18_HTTP_PROVIDER_1_LABEL=My API
R18_HTTP_PROVIDER_1_BASE_URL=
R18_HTTP_PROVIDER_1_API_KEY=
R18_HTTP_PROVIDER_1_API_KEY_HEADER=x-api-key
R18_HTTP_PROVIDER_1_AFFILIATE_FALLBACK_URL=#
R18_HTTP_PROVIDER_1_MERGE_PRIORITY=20
# R18_HTTP_PROVIDER_2_* ... R18_HTTP_PROVIDER_5_*

# Default is OFF for free/fast operation (local device favorites only).
# Set to 1 only when you run with persistent storage (e.g. VPS + volume or DB backend).
NEXT_PUBLIC_ENABLE_ACCOUNT_SYNC=0

# Optional: directory for file-based auth + favorites sync (default: .data under project root).
# On Docker/VPS, set to an absolute path on a mounted volume, e.g. /data
# FANZA_APP_DATA_DIR=/data